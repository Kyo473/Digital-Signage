<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:padding="48dp"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Header row: title + exit button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DS Player — Настройки"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_close"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="#444466"
                android:text="← Назад"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

        </LinearLayout>

        <!-- Server URL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Адрес сервера"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_server_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2d2d4e"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:hint="http://<SERVER_HOST>:3001"
            android:inputType="textUri"
            android:imeOptions="actionDone"
            android:padding="16dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_save_url"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="#444466"
                android:text="Сохранить"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_check_server"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="#334455"
                android:text="Проверить"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Current screen info (shown when screen is assigned) -->
        <LinearLayout
            android:id="@+id/screen_info_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1e3a2a"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_screen_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#52c97e"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_unlink"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="#553333"
                android:text="Отвязать устройство"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

        </LinearLayout>

        <!-- Pairing panel -->
        <LinearLayout
            android:id="@+id/pair_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22223a"
            android:padding="20dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Привязка устройства"
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Big code display (shown after registration) -->
            <LinearLayout
                android:id="@+id/code_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#16163a"
                android:padding="24dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Код устройства"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_code_big"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#6c63ff"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Введите этот код в админке → Устройства"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Код устройства"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2d2d4e"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="ABCD12"
                android:inputType="textCapCharacters"
                android:imeOptions="actionDone"
                android:padding="16dp"
                android:textSize="24sp"
                android:letterSpacing="0.3"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_pair"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="#6c63ff"
                    android:text="Привязать"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_pair_manual"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="#334455"
                    android:text="Новый код"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_pair_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="13sp"
                android:text="Введите код или нажмите «Новый код»." />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
